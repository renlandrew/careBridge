# Vercel server-side environment variables.
# Do not prefix this with VITE_. VITE_ variables are exposed to the browser.
GOOGLE_API_KEY=replace_with_google_ai_studio_key
GEMMA_MODEL=gemma-4-26b-a4b-it

# Optional local override if you want the frontend to call a local Python backend.
# Leave empty for Vercel, where the app uses /api/triage.
# VITE_TRIAGE_ENDPOINT=http://127.0.0.1:8787/triage
